# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-side only, never exposed to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model versions
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_SCAN_MODEL=claude-sonnet-4-6

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The recurring price ID for the MassIQ Premium plan
STRIPE_PRICE_ID=price_...

# Public app URL — used for Stripe success/cancel redirects
NEXT_PUBLIC_APP_URL=https://your-domain.com
